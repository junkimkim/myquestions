# ===========================================
# QuizForge — 환경 변수 (예시)
# 복사: cp .env.example .env.local
# ===========================================

# --- 사이트 URL (OG 메타데이터용, 기본값 https://quizforge.kr) ---
NEXT_PUBLIC_SITE_URL=https://quizforge.kr

# --- Supabase (Dashboard → Project Settings → API) ---
# Phase 0~2: OAuth·세션·RLS에 사용. anon 키는 NEXT_PUBLIC 으로만 노출됩니다.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Phase 2 OAuth: Dashboard → Authentication → URL Configuration
# - Site URL: http://localhost:3000 (운영 시 실제 도메인)
# - Redirect URLs: http://localhost:3000/auth/callback
# Google / Kakao: Authentication → Providers 에서 활성화

# 서버 전용 (절대 클라이언트·Git에 커밋하지 말 것)
# 기존 /api/custom-types 등에서 사용 중
SUPABASE_SERVICE_ROLE_KEY=

# 생성 1회당 차감 캐쉬 (정수 ≥ 1, 기본 1). CASH_* 우선, 없으면 CREDIT_* 호환.
# CASH_COST_PER_GENERATION=1
# NEXT_PUBLIC_CASH_COST_PER_GENERATION=1
# (구호환) CREDIT_COST_PER_GENERATION=1
# NEXT_PUBLIC_CREDIT_COST_PER_GENERATION=1

# --- OpenAI (Phase 4: /api/generate 서버 전용, 필수) ---
# OpenAI Dashboard 에서 발급한 시크릿 키 (sk-...). 클라이언트에 넣지 마세요.
OPENAI_API_KEY=

# --- 토스페이먼츠 (Phase 6: /pricing 결제위젯, /api/payments/toss/*) ---
# SDK v2 (@tosspayments/tosspayments-sdk) — 반드시 「결제위젯 연동」API 키만 사용.
# 「API 개별 연동」클라이언트/시크릿은 결제위젯과 호환되지 않습니다(대시보드에서 구분 발급).
# 개발자센터 → API 키 → 결제위젯 연동: test_ck_ / test_sk_ (테스트), live_ck_ / live_sk_ (운영)
# NEXT_PUBLIC_TOSS_PAYMENTS_CLIENT_KEY=
# TOSS_PAYMENTS_SECRET_KEY=
# (선택) 웹훅 서명 검증 등
# TOSS_PAYMENTS_SECURITY_KEY=
# (선택) 대시보드에 만든 UI variant 키 — 기본 DEFAULT
# NEXT_PUBLIC_TOSS_PAYMENTS_WIDGET_VARIANT_KEY=DEFAULT
# NEXT_PUBLIC_TOSS_PAYMENTS_AGREEMENT_VARIANT_KEY=DEFAULT
